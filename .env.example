# ─── Database ─────────────────────────────────────────────
POSTGRES_USER=skillmaker
POSTGRES_PASSWORD=changeme-strong-password-prod
POSTGRES_DB=skillmaker
DATABASE_URL=postgres://skillmaker:changeme-strong-password-prod@postgres:5432/skillmaker?sslmode=disable

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=CHANGE-ME-32-CHARS-MINIMUM-USE-openssl-rand-base64-48
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=168h
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx
GOOGLE_HOSTED_DOMAIN=tuempresa.com
GOOGLE_REDIRECT_URI=https://app.tuempresa.com/api/auth/google/callback

# ─── Storage (MinIO embebido o S3 externo) ────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme-minio-prod
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=skillmaker-materials
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=changeme-minio-prod
STORAGE_USE_SSL=false
STORAGE_PRESIGN_TTL=15m
MAX_UPLOAD_BYTES=52428800

# ─── Server ───────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info
ALLOWED_ORIGINS=
